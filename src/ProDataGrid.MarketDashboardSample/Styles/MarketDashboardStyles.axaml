  </Style>

  <Style Selector="Path.inline-icon">
    <Setter Property="Fill" Value="{StaticResource DashboardMutedBrush}" />
    <Setter Property="Stretch" Value="Uniform" />
  </Style>

  <Style Selector="Path.inline-icon.positive">
    <Setter Property="Fill" Value="{StaticResource DashboardPositiveBrush}" />
  </Style>

  <Style Selector="Button.wallet-button">
    <Setter Property="Background" Value="{StaticResource DashboardBlueBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource DashboardBlueBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Padding" Value="14,10" />
    <Setter Property="FontWeight" Value="Bold" />
  </Style>

  <Style Selector="Button.wallet-button:pointerover">
    <Setter Property="Background" Value="#5E7BFF" />
  </Style>

  <Style Selector="DataGrid.terminal-grid">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Foreground" Value="{StaticResource DashboardTextBrush}" />
    <Setter Property="GridLinesVisibility" Value="Horizontal" />
    <Setter Property="HeadersVisibility" Value="Column" />
  </Style>

  <Style Selector="DataGrid.terminal-grid DataGridColumnHeader">
    <Setter Property="Background" Value="#0C1320" />
    <Setter Property="Foreground" Value="{StaticResource DashboardMutedBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource DashboardSeparatorBrush}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
    <Setter Property="Padding" Value="8,8" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="FontSize" Value="11" />
  </Style>

  <Style Selector="DataGrid.terminal-grid DataGridCell">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{StaticResource DashboardSeparatorBrush}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
    <Setter Property="Padding" Value="8,8" />
  </Style>

  <Style Selector="DataGrid.terminal-grid DataGridRow">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="DataGrid.terminal-grid DataGridRow:pointerover">
    <Setter Property="Background" Value="#131D30" />
  </Style>

  <Style Selector="DataGrid.watchlist-grid DataGridColumnHeader">
    <Setter Property="Background" Value="#0E1523" />
    <Setter Property="Padding" Value="4,6" />
    <Setter Property="FontSize" Value="10" />
  </Style>

  <Style Selector="DataGrid.watchlist-grid DataGridCell">
    <Setter Property="Padding" Value="3,5" />
  </Style>

  <Style Selector="DataGrid.watchlist-grid DataGridRow:pointerover">
    <Setter Property="Background" Value="#111A29" />
  </Style>

  <Style Selector="DataGrid.watchlist-grid DataGridRow:selected">
    <Setter Property="Background" Value="#141F31" />
  </Style>

  <Style Selector="DataGrid.watchlist-grid DataGridRow">
    <Setter Property="MinHeight" Value="40" />
  </Style>

  <Style Selector="DataGrid.trade-grid DataGridCell">
    <Setter Property="Padding" Value="8,9" />
  </Style>

</Styles>
