  </Style>

  <Style Selector="Button.toolbar-link-button Path.fluent-icon">
    <Setter Property="Fill" Value="{StaticResource DashboardTextBrush}" />
  </Style>

  <Style Selector="Button.toolbar-link-button.active Path.fluent-icon">
    <Setter Property="Fill" Value="#8091FF" />
  </Style>

  <Style Selector="Button.toolbar-link-button:pointerover Path.fluent-icon">
    <Setter Property="Fill" Value="#B9C3FF" />
  </Style>

  <Style Selector="RadioButton.chart-toggle">
    <Setter Property="Background" Value="#343A4E" />
    <Setter Property="BorderBrush" Value="#343A4E" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="8,4" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="FontSize" Value="11" />
  </Style>

  <Style Selector="RadioButton.chart-toggle:checked">
    <Setter Property="Background" Value="{StaticResource DashboardBlueBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource DashboardBlueBrush}" />
  </Style>

  <Style Selector="Button.chart-nav-button">
    <Setter Property="Background" Value="#182238" />
    <Setter Property="BorderBrush" Value="#25314A" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="8,4" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="FontSize" Value="11" />
  </Style>

  <Style Selector="Button.chart-nav-button:pointerover">
