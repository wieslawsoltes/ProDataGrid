  <Style Selector="RadioButton.order-toggle">
    <Setter Property="Background" Value="#3B3D4F" />
    <Setter Property="BorderBrush" Value="#3B3D4F" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
