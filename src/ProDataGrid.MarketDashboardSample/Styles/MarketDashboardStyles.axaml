    <Setter Property="BorderBrush" Value="{StaticResource DashboardSeparatorBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="10,6" />
  </Style>

  <Style Selector="ToggleButton.dex-mode-toggle:pointerover">
