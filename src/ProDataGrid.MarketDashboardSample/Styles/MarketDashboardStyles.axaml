    <Setter Property="Padding" Value="10,6" />
  </Style>

  <Style Selector="Button.strip-action-button">
    <Setter Property="Background" Value="#1A2D61" />
    <Setter Property="BorderBrush" Value="#3554CC" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="10,6" />
