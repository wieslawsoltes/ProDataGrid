<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Avalonia.Diagnostics.Views"
             xmlns:vm="using:Avalonia.Diagnostics.ViewModels"
             xmlns:lb="using:Avalonia.Diagnostics.Behaviors"
             x:Class="Avalonia.Diagnostics.Views.ControlDetailsView"
             x:DataType="vm:ControlDetailsViewModel">

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*"/>
      <ColumnDefinition Width="Auto"/>
      <!--
      When selecting the Application node, hide Layout Visualizer by collapsing
      the column itself. GridSplitter writes Width onto ColumnDefinition, so
      hiding only the child would leave reserved space behind.
      -->
      <ColumnDefinition Width="320"
                        lb:ColumnDefinition.IsVisible="{Binding Layout, Converter={x:Static ObjectConverters.IsNotNull}}" />
    </Grid.ColumnDefinitions>

    <local:ControlPropertiesView Grid.Column="0" />

    <GridSplitter Grid.Column="1"
                  IsVisible="{Binding Layout, Converter={x:Static ObjectConverters.IsNotNull}}" />

    <local:ControlLayoutStylesView Grid.Column="2" />
  </Grid>
</UserControl>
