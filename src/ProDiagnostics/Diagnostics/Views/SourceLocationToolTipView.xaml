<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Avalonia.Diagnostics.Views.SourceLocationToolTipView"
             x:Name="Root">
  <StackPanel MaxWidth="540"
              Spacing="6">
    <TextBlock Text="{Binding #Root.SourceLocation, TargetNullValue='Source location not available.'}"
               TextWrapping="Wrap" />
    <Button Command="{Binding #Root.OpenSourceLocationCommand}"
            CommandParameter="{Binding #Root.SourceLocation}"
            Background="Transparent"
            BorderThickness="0"
            Padding="0"
            HorizontalAlignment="Left">
      <TextBlock Text="{Binding #Root.OpenLinkText}"
                 Foreground="#1F5FBF"
                 TextDecorations="Underline" />
    </Button>
  </StackPanel>
</UserControl>
